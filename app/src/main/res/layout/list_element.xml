<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:padding="15dp">

    <TextView
        android:id="@+id/firstLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textAppearance="@style/cardItemPersonName" />

    <TextView
        android:id="@+id/secondLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignLeft="@id/firstLine"
        android:layout_alignStart="@id/firstLine"
        android:layout_below="@id/firstLine"
        android:layout_marginTop="5dp"
        android:textAppearance="@style/cardItemComment" />

    <TextView
        android:id="@+id/firstLineDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_alignTop="@id/firstLine"
        android:text="07 mar 2017"
        android:visibility="gone"
        android:textAppearance="@style/cardItemCommentDate" />

</RelativeLayout>